{
  "$defs": {
    "SourceEvidenceClaim": {
      "additionalProperties": false,
      "description": "A prose claim linked explicitly to stable source IDs.",
      "properties": {
        "claim": {
          "title": "Claim",
          "type": "string"
        },
        "source_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Ids",
          "type": "array"
        }
      },
      "required": [
        "claim",
        "source_ids"
      ],
      "title": "SourceEvidenceClaim",
      "type": "object"
    },
    "SourceLedgerEntry": {
      "additionalProperties": false,
      "description": "A traceable source record returned by the compiler.",
      "properties": {
        "evidence_claims": {
          "items": {
            "$ref": "#/$defs/SourceEvidenceClaim"
          },
          "title": "Evidence Claims",
          "type": "array"
        },
        "identifiers": {
          "items": {
            "type": "string"
          },
          "title": "Identifiers",
          "type": "array"
        },
        "required_for_claim": {
          "title": "Required For Claim",
          "type": "boolean"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "verification_detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Verification Detail"
        },
        "verified": {
          "title": "Verified",
          "type": "boolean"
        }
      },
      "required": [
        "source_id",
        "title",
        "identifiers",
        "evidence_claims",
        "required_for_claim",
        "verified",
        "verification_detail"
      ],
      "title": "SourceLedgerEntry",
      "type": "object"
    },
    "WorkerStatus": {
      "enum": [
        "progress",
        "blocked",
        "refuted",
        "candidate_complete"
      ],
      "title": "WorkerStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "assignment_id": {
      "title": "Assignment Id",
      "type": "string"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "counterexamples": {
      "items": {
        "type": "string"
      },
      "title": "Counterexamples",
      "type": "array"
    },
    "dependencies": {
      "items": {
        "type": "string"
      },
      "title": "Dependencies",
      "type": "array"
    },
    "exact_gap": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Exact Gap"
    },
    "formal_results": {
      "items": {
        "type": "string"
      },
      "title": "Formal Results",
      "type": "array"
    },
    "mechanism": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Mechanism"
    },
    "proof_content": {
      "title": "Proof Content",
      "type": "string"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/SourceLedgerEntry"
      },
      "title": "Sources",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/WorkerStatus"
    }
  },
  "required": [
    "assignment_id",
    "status",
    "formal_results",
    "proof_content",
    "exact_gap",
    "sources",
    "assumptions",
    "counterexamples",
    "dependencies",
    "mechanism"
  ],
  "title": "ResearchWorkerReport",
  "type": "object"
}
