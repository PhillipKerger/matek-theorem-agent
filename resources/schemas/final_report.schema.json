{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "run_id",
    "scientific_status",
    "manuscript_status",
    "lean_status",
    "strongest_result",
    "unresolved_obligations",
    "artifacts"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "scientific_status": {
      "type": "string"
    },
    "manuscript_status": {
      "type": "string"
    },
    "lean_status": {
      "type": "string"
    },
    "strongest_result": {
      "type": "string"
    },
    "unresolved_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "object"
    },
    "problem_clarification": {
      "type": "object"
    },
    "literature_status": {
      "type": "string"
    },
    "literature_resolution_summary": {
      "type": ["string", "null"]
    },
    "knowledge_graph": {
      "type": "object",
      "properties": {
        "problem_id": {"type": "string"},
        "revision": {"type": "string"},
        "vault": {"type": "string"},
        "index": {"type": "string"},
        "validation_warnings": {
          "type": "array",
          "items": {"type": "string"}
        },
        "status": {"type": "object"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
