{
  "$defs": {
    "ClaimContract": {
      "additionalProperties": false,
      "description": "Closed representation of an extensible theorem claim contract.",
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/ClaimContractEntry"
          },
          "title": "Entries",
          "type": "array"
        }
      },
      "required": [
        "entries"
      ],
      "title": "ClaimContract",
      "type": "object"
    },
    "ClaimContractEntry": {
      "additionalProperties": false,
      "description": "One named, theorem-specific clause in a compiled claim contract.",
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ],
      "title": "ClaimContractEntry",
      "type": "object"
    },
    "LiteratureStatus": {
      "description": "Best verified relationship between the requested target and prior literature.",
      "enum": [
        "unknown",
        "no_exact_match_found",
        "partially_resolved",
        "fully_resolved"
      ],
      "title": "LiteratureStatus",
      "type": "string"
    },
    "PromptCompilationStatus": {
      "description": "Whether a unique research target could be compiled safely.",
      "enum": [
        "compiled",
        "needs_clarification"
      ],
      "title": "PromptCompilationStatus",
      "type": "string"
    },
    "SourceEvidenceClaim": {
      "additionalProperties": false,
      "description": "A prose claim linked explicitly to stable source IDs.",
      "properties": {
        "claim": {
          "title": "Claim",
          "type": "string"
        },
        "source_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Ids",
          "type": "array"
        }
      },
      "required": [
        "claim",
        "source_ids"
      ],
      "title": "SourceEvidenceClaim",
      "type": "object"
    },
    "SourceLedgerEntry": {
      "additionalProperties": false,
      "description": "A traceable source record returned by the compiler.",
      "properties": {
        "evidence_claims": {
          "items": {
            "$ref": "#/$defs/SourceEvidenceClaim"
          },
          "title": "Evidence Claims",
          "type": "array"
        },
        "identifiers": {
          "items": {
            "type": "string"
          },
          "title": "Identifiers",
          "type": "array"
        },
        "required_for_claim": {
          "title": "Required For Claim",
          "type": "boolean"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "verification_detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Verification Detail"
        },
        "verified": {
          "title": "Verified",
          "type": "boolean"
        }
      },
      "required": [
        "source_id",
        "title",
        "identifiers",
        "evidence_claims",
        "required_for_claim",
        "verified",
        "verification_detail"
      ],
      "title": "SourceLedgerEntry",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Structured model output specified by ``compiled_problem.schema.json``.",
  "properties": {
    "candidate_interpretations": {
      "items": {
        "type": "string"
      },
      "title": "Candidate Interpretations",
      "type": "array"
    },
    "claim_contract": {
      "$ref": "#/$defs/ClaimContract"
    },
    "clarification_questions": {
      "items": {
        "type": "string"
      },
      "title": "Clarification Questions",
      "type": "array"
    },
    "clarification_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Clarification Reason"
    },
    "compiled_prompt": {
      "title": "Compiled Prompt",
      "type": "string"
    },
    "literature_resolution_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Literature Resolution Summary"
    },
    "literature_status": {
      "$ref": "#/$defs/LiteratureStatus"
    },
    "normalized_statement": {
      "title": "Normalized Statement",
      "type": "string"
    },
    "source_ledger": {
      "items": {
        "$ref": "#/$defs/SourceLedgerEntry"
      },
      "title": "Source Ledger",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/PromptCompilationStatus"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "unresolved_ambiguities": {
      "items": {
        "type": "string"
      },
      "title": "Unresolved Ambiguities",
      "type": "array"
    }
  },
  "required": [
    "status",
    "title",
    "normalized_statement",
    "claim_contract",
    "compiled_prompt",
    "source_ledger",
    "unresolved_ambiguities",
    "clarification_reason",
    "clarification_questions",
    "candidate_interpretations",
    "literature_status",
    "literature_resolution_summary"
  ],
  "title": "CompiledProblem",
  "type": "object"
}
